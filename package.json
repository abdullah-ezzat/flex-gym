{
  "displayName": "Flex Gym",
  "name": "flex-gym",
  "description": "Flex Gym Desktop Application",
  "version": "0.0.0",
  "main": "dist/main/index.js",
  "resources": "src/resources",
  "author": {
    "name": "Abdullah M. Ezzat",
    "email": "abdullahmohamedezzat21@gmail.com"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "./trusted-dependencies-scripts.json"
    ],
    "overrides": {
      "node-gyp": "^12.2.0"
    }
  },
  "build": {
    "appId": "com.flexgym.app",
    "productName": "Flex Gym",
    "copyright": "© 2026 Flex Gym. All rights reserved.",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/resources/public/flex.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "icon": "src/resources/public/flex.png"
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "pnpm build && electron-builder --win --x64",
    "build:portable": "pnpm build && electron-builder --win portable --x64",
    "build:linux": "pnpm build && electron-builder --linux",
    "preview": "electron-vite preview",
    "clean": "rimraf dist release"
  },
  "dependencies": {
    "@electron/rebuild": "^4.0.3",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-router-dom": "^2.1.0",
    "framer-motion": "^12.34.3",
    "html5-qrcode": "^2.3.8",
    "jsonwebtoken": "^9.0.3",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.556.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.10.1",
    "react-tsparticles": "^2.12.2",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "tsparticles": "^3.9.1",
    "tsparticles-slim": "^2.12.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@tailwindcss/vite": "^4.1.17",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "code-inspector-plugin": "^1.3.0",
    "cross-env": "^10.1.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.1",
    "rimraf": "^6.1.2",
    "rollup-plugin-inject-process-env": "^1.3.1",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
